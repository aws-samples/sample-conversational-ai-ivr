AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
AWS_PROFILE=your-profile-name

ENVIRONMENT=dev
STACK_NAME=anycompany-ivr
INSTANCE_ALIAS=anycompany-ivr-demo

CFN_BUCKET=your-cfn-bucket-name
CFN_PREFIX=anycompany-ivr/templates
KB_BUCKET=your-kb-bucket-name

CONNECT_INSTANCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WISDOM_ASSISTANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

PARK_AND_TOLL_BOT_ID=XXXXXXXXXX
PARK_AND_TOLL_BOT_ALIAS_ID=XXXXXXXXXX
PAYMENT_BOT_ID=XXXXXXXXXX
PAYMENT_BOT_ALIAS_ID=XXXXXXXXXX

API_GATEWAY_ID=xxxxxxxxxx
API_GATEWAY_STAGE=dev

AGENTCORE_GATEWAY_ID=your-gateway-id
AGENTCORE_TARGET_NAME=anycompanyDemoIVRApi

SESSION_TABLE_NAME=ivr-dev-IVRSessionContext
CUSTOMERS_TABLE=anycompany-ivr-customers-dev
VIOLATIONS_TABLE=anycompany-ivr-violations-dev
