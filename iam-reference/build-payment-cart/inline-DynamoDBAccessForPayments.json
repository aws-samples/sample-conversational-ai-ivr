{
    "RoleName": "anycompany-ivr-payments-lambda-role-dev",
    "PolicyName": "DynamoDBAccessForPayments",
    "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Action": [
                    "dynamodb:GetItem",
                    "dynamodb:PutItem",
                    "dynamodb:UpdateItem",
                    "dynamodb:DeleteItem",
                    "dynamodb:Query"
                ],
                "Resource": [
                    "arn:aws:dynamodb:us-east-1:123456789012:table/ivr-dev-IVRSessionContext"
                ],
                "Effect": "Allow"
            },
            {
                "Action": [
                    "dynamodb:GetItem",
                    "dynamodb:UpdateItem",
                    "dynamodb:Query"
                ],
                "Resource": [
                    "arn:aws:dynamodb:us-east-1:123456789012:table/anycompany-ivr-violations-dev",
                    "arn:aws:dynamodb:us-east-1:123456789012:table/anycompany-ivr-violations-dev/index/*"
                ],
                "Effect": "Allow"
            }
        ]
    }
}
